# ==============================
# API / Flask Server Configuration
# ==============================
# Host donde corre el servidor Flask (ej: localhost, 0.0.0.0)
APP_HOST=localhost
# Puerto del servidor Flask
APP_PORT=5000
# Modo debug de Flask (True para desarrollo, False para producción)
APP_DEBUG=True
# URL del frontend permitida por CORS (ej: http://localhost:5173)
CORS_ORIGINS=http://localhost:5173

# ==============================
# Configuración de correo (Flask-Mail / SMTP)
# ==============================
# Servidor SMTP para envío de correos (ej: smtp.gmail.com)
MAIL_SERVER=smtp.gmail.com
# Puerto del servidor SMTP (587 para TLS, 465 para SSL)
MAIL_PORT=587
# Correo electrónico desde el cual se envían los emails
MAIL_USERNAME=tu_correo@gmail.com
# Contraseña de aplicación del correo (NO tu contraseña normal, genera una en https://myaccount.google.com/apppasswords)
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
# Usar TLS para la conexión SMTP
MAIL_USE_TLS=True
# Usar SSL para la conexión SMTP (no usar junto con TLS)
MAIL_USE_SSL=False

# ==============================
# Base de datos (PostgreSQL + SQLAlchemy)
# ==============================
# URL de conexión a PostgreSQL: postgresql://usuario:contraseña@host:puerto/nombre_db
DB_URL=postgresql://postgres:tu_password@localhost:5432/postgres
# Schema de PostgreSQL donde se crean las tablas
DB_SCHEMA=paw_store

# ==============================
# JWT (JSON Web Token) - Autenticación
# ==============================
# Clave secreta para firmar los tokens JWT (usa un string largo y aleatorio en producción)
SECRET_KEY=tu_clave_secreta
# Algoritmo de encriptación para JWT (ej: HS256, HS384, HS512)
JWT_ALGORITHM=HSXXX